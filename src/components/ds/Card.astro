---
interface Props {
  title?: string;
  compact?: boolean;
  elevated?: boolean;
  class?: string;
}

const { title, compact = false, elevated = false, class: className = "" } = Astro.props;

const classes = [
  "ds-card",
  compact ? "ds-card--compact" : "",
  elevated ? "ds-card--elevated" : "",
  className,
]
  .filter(Boolean)
  .join(" ");
---

<div class={classes}>
  {title && <p class="ds-card__title">{title}</p>}
  <div class="ds-card__body">
    <slot />
  </div>
</div>

<style>
  .ds-card {
    background-color: color-mix(in oklch, var(--color-bg) 88%, var(--color-surface));
    border: 1px solid color-mix(in oklch, var(--color-line) 80%, var(--color-primary) 8%);
    border-radius: var(--radius-lg);
    padding: var(--space-lg);
    box-shadow: var(--shadow-linen);
    transition:
      box-shadow var(--duration-normal) var(--ease-out-quart),
      border-color var(--duration-normal) var(--ease-out-quart),
      transform var(--duration-fast) var(--ease-groove);
  }

  .ds-card--elevated:hover {
    box-shadow: var(--shadow-lift);
    border-color: color-mix(in oklch, var(--color-primary) 20%, var(--color-line));
    transform: translateY(-2px);
  }

  .ds-card--compact {
    padding: var(--space-md);
  }

  .ds-card__title {
    font-family: var(--font-display);
    font-size: var(--text-heading);
    font-weight: 600;
    color: var(--color-ink);
    margin: 0 0 var(--space-sm) 0;
    max-width: none;
    letter-spacing: -0.02em;
  }

  .ds-card__body {
    color: var(--color-muted);
    font-size: var(--text-secondary);
    line-height: 1.55;
  }
</style>
