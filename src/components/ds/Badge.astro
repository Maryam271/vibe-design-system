---
interface Props {
  tone?: "neutral" | "ocean" | "aurora" | "moment" | "deep" | "gold" | "green" | "coral";
  class?: string;
}

const { tone = "neutral", class: className = "" } = Astro.props;

const classes = [
  "ds-badge",
  `ds-badge--${tone}`,
  className,
]
  .filter(Boolean)
  .join(" ");
---

<span class={classes}><slot /></span>

<style>
  .ds-badge {
    display: inline-flex;
    align-items: center;
    font-family: var(--font-body);
    font-size: var(--text-caption);
    font-weight: 600;
    line-height: 1;
    padding: 0.35em 0.75em;
    border-radius: var(--radius-pill);
    border: 1px solid transparent;
    white-space: nowrap;
    letter-spacing: 0.01em;
  }

  .ds-badge--neutral {
    background-color: var(--color-surface);
    color: var(--color-ink);
    border-color: var(--color-line);
  }

  .ds-badge--ocean {
    background-color: color-mix(in oklch, var(--color-primary) 14%, var(--color-bg));
    color: var(--color-primary-hover);
    border-color: color-mix(in oklch, var(--color-primary) 25%, var(--color-line));
  }

  .ds-badge--aurora,
  .ds-badge--gold {
    background-color: var(--color-accent-soft);
    color: var(--color-accent);
    border-color: color-mix(in oklch, var(--color-accent) 20%, var(--color-line));
  }

  .ds-badge--moment,
  .ds-badge--green {
    background-color: color-mix(in oklch, var(--color-moment) 16%, var(--color-bg));
    color: var(--color-moment-hover);
    border-color: color-mix(in oklch, var(--color-moment) 30%, var(--color-line));
  }

  .ds-badge--deep {
    background-color: var(--color-ocean-deep);
    color: var(--color-bg);
    border-color: var(--color-ocean-deep);
  }

  .ds-badge--coral {
    background-color: color-mix(in oklch, var(--color-coral) 40%, var(--color-bg));
    color: oklch(0.45 0.06 75);
    border-color: color-mix(in oklch, var(--color-coral) 50%, var(--color-line));
  }
</style>
