---
interface Props {
  heading: string;
  lede?: string;
  id?: string;
  tight?: boolean;
  class?: string;
}

const { heading, lede, id, tight = false, class: className = "" } = Astro.props;

const classes = ["ds-section", tight ? "ds-section--tight" : "", className]
  .filter(Boolean)
  .join(" ");
---

<section class={classes} id={id}>
  <div class="ds-section__header">
    <span class="ds-section__eyebrow" aria-hidden="true"></span>
    <h2 class="ds-section__heading">{heading}</h2>
    {lede && <p class="ds-section__lede">{lede}</p>}
  </div>
  <div class="ds-section__content">
    <slot />
  </div>
</section>

<style>
  .ds-section {
    padding-top: var(--space-2xl);
    padding-bottom: var(--space-2xl);
    border-bottom: 1px solid color-mix(in oklch, var(--color-line) 70%, transparent);
  }

  .ds-section:last-of-type {
    border-bottom: none;
  }

  .ds-section--tight {
    padding-top: var(--space-xl);
    padding-bottom: var(--space-xl);
  }

  .ds-section__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    margin-bottom: var(--space-xl);
  }

  .ds-section__eyebrow {
    display: block;
    width: 2.5rem;
    height: 3px;
    border-radius: var(--radius-pill);
    background: linear-gradient(
      90deg,
      var(--color-primary),
      var(--color-accent)
    );
  }

  .ds-section__heading {
    font-size: var(--text-heading);
    font-family: var(--font-display);
    font-weight: 600;
    letter-spacing: -0.02em;
    text-transform: none;
    color: var(--color-ink);
    margin: 0;
  }

  .ds-section__lede {
    font-size: var(--text-secondary);
    color: var(--color-muted);
    max-width: 55ch;
    margin: 0;
    line-height: 1.55;
  }

  .ds-section__content {
    animation: section-in var(--duration-groove) var(--ease-out-quart) both;
  }

  @keyframes section-in {
    from {
      opacity: 0;
      transform: translateY(8px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
