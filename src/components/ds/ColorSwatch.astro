---
interface Props {
  name: string;
  token: string;
  light?: boolean;
  class?: string;
}

const { name, token, light = false, class: className = "" } = Astro.props;

const classes = ["ds-swatch", light ? "ds-swatch--light" : "", className]
  .filter(Boolean)
  .join(" ");
---

<div class={classes}>
  <div class="ds-swatch__chip" style={`background: var(${token})`}></div>
  <div class="ds-swatch__meta">
    <span class="ds-swatch__name">{name}</span>
    <span class="ds-swatch__token">{token}</span>
  </div>
</div>

<style>
  .ds-swatch {
    display: flex;
    flex-direction: column;
    gap: 0;
    border: 1px solid color-mix(in oklch, var(--color-line) 80%, var(--color-primary) 8%);
    border-radius: var(--radius-lg);
    overflow: hidden;
    background-color: color-mix(in oklch, var(--color-bg) 85%, var(--color-surface));
    box-shadow: var(--shadow-linen);
    transition:
      transform var(--duration-fast) var(--ease-groove),
      box-shadow var(--duration-normal) var(--ease-out-quart);
  }

  .ds-swatch:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-lift);
  }

  .ds-swatch__chip {
    height: 4.5rem;
    width: 100%;
  }

  .ds-swatch__meta {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    padding: var(--space-sm) var(--space-md);
    border-top: 1px solid color-mix(in oklch, var(--color-line) 60%, transparent);
  }

  .ds-swatch__name {
    font-family: var(--font-body);
    font-size: var(--text-caption);
    font-weight: 700;
    color: var(--color-ink);
  }

  .ds-swatch__token {
    font-family: ui-monospace, "Cascadia Code", "Source Code Pro", monospace;
    font-size: 0.7rem;
    color: var(--color-muted);
    word-break: break-all;
  }
</style>
